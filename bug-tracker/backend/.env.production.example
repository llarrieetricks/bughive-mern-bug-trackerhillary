# Production Environment Variables for BugHive Backend
# Copy this file to .env when deploying and fill in your actual values

# === REQUIRED ===
# MongoDB connection string (use MongoDB Atlas for production)
# Format: mongodb+srv://username:password@cluster.mongodb.net/database
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/bughive

# Secret key for JWT token generation (use a strong, random string)
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_123456

# === OPTIONAL ===
# Server port (Render auto-detects this, default: 5000)
PORT=5000

# Environment mode (production/development)
NODE_ENV=production

# Frontend URL (for CORS - Vercel deployment URL)
# Example: https://bughive.vercel.app
FRONTEND_URL=https://bughive.vercel.app
